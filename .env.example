# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Required: get from https://my.telegram.org/apps
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Session file name (creates tg_downloader.session on first login)
TG_SESSION_NAME=tg_downloader

# How many files download at the same time (2–4 is usually best on Windows)
TG_CONCURRENCY=2
TG_MAX_GLOBAL_DOWNLOADS=2

# Retries per file on network/API errors
TG_MAX_RETRIES=5

# Extra wait before each file (0 = fastest; FloodWait is handled automatically)
TG_DOWNLOAD_DELAY=0

# Where downloaded channel folders are saved
TG_OUTPUT_DIR=downloads

# Streaming chunk size in bytes (2097152 = 2 MB, 4194304 = 4 MB)
TG_REQUEST_SIZE_BYTES=2097152

# How often manifest.json is flushed to disk
TG_MANIFEST_FLUSH_FILES=20
TG_MANIFEST_FLUSH_SECONDS=30

# Terminal progress refresh interval (seconds); higher = less UI overhead on Windows
TG_PROGRESS_UPDATE_SEC=1.5

# Multipart download (recommended for large videos; can reach ~10–15 MB/s in good conditions)
TG_ENABLE_MULTIPART=true
TG_PART_SIZE_MB=8
TG_MAX_PARALLEL_PARTS=4
TG_MERGE_BUFFER_MB=16
